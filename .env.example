# # ─── Afterma AI Backend — Environment Variables ──────────────────────────────
# # Copy this file to .env and fill in your values

# # ── OpenAI (Required for LangChain RAG + Embeddings) ─────────────────────────
# OPENAI_API_KEY=sk-proj-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# # ── MongoDB (Required for vector storage) ────────────────────────────────────
# # Option A — MongoDB Atlas (recommended for production):
# MONGODB_URI=mongodb+srv://aftermateam:XzM8NVOok3YoU92Q@cluster0.cuea1c8.mongodb.net/
# # Option B — Local MongoDB:
# # MONGODB_URI=mongodb://localhost:27017

# MONGODB_DB_NAME=afterma_ai
# MONGODB_COLLECTION=documents
# # Name of the Atlas Search index (must match what you create in Atlas UI)
# MONGODB_INDEX_NAME=vector_index

# # ── LangSmith (Optional — tracing & monitoring) ───────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your_langsmith_key_here
# LANGCHAIN_PROJECT=afterma-ai-chatbot
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# # ── Legacy OpenRouter (Kept for src/ fallback) ────────────────────────────────
# OPENROUTER_API_KEY=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
# OPENROUTER_MODEL=google/gemma-3-27b-it:free

# # ── Server ────────────────────────────────────────────────────────────────────
# PORT=5000
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://afterma.netlify.app/

# # ── RAG Settings ──────────────────────────────────────────────────────────────
# RAG_K=5
# MEMORY_MAX_TOKENS=2000
